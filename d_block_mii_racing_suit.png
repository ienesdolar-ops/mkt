<script>			ff.pluginAddInit("ff.ajax", function () {
				ff.ajax.addEvent({
					"event_name"	: "onSuccess"
					, "func_name"	: function (data, params, injectid) {
						if (data.modules && data.modules.security) {
							// update session data
							ff.modules.security.session.csrf.value	= data.modules.security.csrf_value;
							jQuery("#" + ff.modules.security.session.csrf.param).val(data.modules.security.csrf_value);						}
					}
				});
				ff.addEvent({
					"event_name" : "fixFields"
					, "func_name" : function (fields, lastret) {
						let ret = lastret || fields;
						
						if (!ret) {
						    return ret;
						}

                        ret.unbufferedEach(function (i, v) {
                            if (v.name === ff.modules.security.session.csrf.param) {
                                if (ff.modules.security.session.loggedin) {
                                    v.value = ff.modules.security.session.csrf.value;
                                } else {
                                    ret.unset(i);
                                }
                            }
                        });
			
						return ret;
					}
				});
			}, "0a1f6a4f-2177-42ca-92e2-89bd35b0dab7");</script>

<script>jQuery(function ($, undefined) {
	ff.pluginAddInit("ff.modules.security", function () {
		
		ff.modules.security.services.login = '/login/';
		
		
		
		ff.modules.security.services.oauth2 = '/services/oauth2/';
		
		ff.modules.security.session.session_name = 'PHPSESSBDG';
		
		
		ff.modules.security.session.csrf || (ff.modules.security.session.csrf = {});
		ff.modules.security.session.csrf.param	= '_CSRF_';
		ff.modules.security.session.csrf.value	= undefined;
		
		
		ff.modules.security.services.register.activation_resend	= '/services/mod_security/register/resend_activation';
		
	}, '8300e66c-01a7-4dda-b59d-426f235c4ed4');
}(jQuery));
</script>

